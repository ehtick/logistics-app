{
  "name": "@logisticsx/angular",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start:tms": "ng serve tms-portal",
    "start:customer": "ng serve customer-portal",
    "start:admin": "ng serve admin-portal",
    "start:website": "ng serve website",
    "build:shared": "ng build shared",
    "build:tms": "ng build tms-portal",
    "build:customer": "ng build customer-portal",
    "build:admin": "ng build admin-portal",
    "build:website": "ng build website",
    "build:all": "bun run build:shared && ng build tms-portal && ng build customer-portal && ng build admin-portal && ng build website",
    "test": "ng test",
    "lint": "ng lint",
    "check": "node tools/checks/index.mjs",
    "check:spartan-tokens": "node tools/checks/spartan-tokens.mjs",
    "check:theme-tokens": "node tools/checks/theme-tokens.mjs",
    "ui:normalize": "node tools/normalize-helm.mjs",
    "format": "prettier --write ./projects",
    "gen:api": "ng-openapi-gen && bun scripts/fix-verbatim-imports.ts",
    "gen:api:live": "bun scripts/fetch-openapi.ts && bun run gen:api"
  },
  "dependencies": {
    "@angular/animations": "^22.0.6",
    "@angular/cdk": "^22.0.4",
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.6",
    "@angular/platform-browser": "^22.0.6",
    "@angular/platform-server": "^22.0.6",
    "@angular/router": "^22.0.6",
    "@angular/ssr": "^22.0.6",
    "@microsoft/signalr": "^10.0.0",
    "@ng-icons/core": "^34.0.0",
    "@ng-icons/lucide": "^34.0.0",
    "@ngrx/signals": "^21.1.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@spartan-ng/brain": "^1.1.0",
    "angular-auth-oidc-client": "^21.0.2",
    "angular-gridster2": "^22.0.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "mapbox-gl": "^3.20.0",
    "marked": "^18.0.3",
    "ngx-mapbox-gl": "^14.0.0",
    "quill": "^2.0.3",
    "rxjs": "^7.8.2",
    "tailwind-merge": "^3.6.0",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^22.0.0",
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "@eslint/js": "^9.39.1",
    "@spartan-ng/cli": "1.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/express": "^5.0.1",
    "@types/geojson": "^7946.0.16",
    "@types/mapbox-gl": "^3.5.0",
    "@types/node": "^25.5.0",
    "angular-eslint": "^22.0.0",
    "eslint": "^9.39.1",
    "jsdom": "^29.1.1",
    "ng-openapi-gen": "^1.0.5",
    "ng-packagr": "^22.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
